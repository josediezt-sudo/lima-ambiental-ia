# Postgres
POSTGRES_USER=lima_ambiental
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=lima_ambiental
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lima_ambiental:cambia_esta_clave@localhost:5432/lima_ambiental

# OpenAQ (https://explore.openaq.org/register)
# La búsqueda de estaciones usa el bounding box de los 43 distritos (tabla
# `distritos`), no hace falta configurar coordenadas aquí.
OPENAQ_API_KEY=

# Residuos — PNDA / CKAN (verificar el slug real del dataset en datosabiertos.gob.pe)
RESIDUOS_CKAN_BASE_URL=https://www.datosabiertos.gob.pe
RESIDUOS_CKAN_PACKAGE_ID=

# Agua / ruido / áreas verdes — datasets CKAN genéricos, ver config/fuentes_ckan.yml
# (copia config/fuentes_ckan.example.yml y completa los package_id reales)
FUENTES_CKAN_CONFIG=config/fuentes_ckan.yml

# NASA FIRMS — focos de calor/incendios (https://firms.modaps.eosdis.nasa.gov/api/map_key/)
FIRMS_MAP_KEY=

# Global Forest Watch — alertas de pérdida de cobertura vegetal (lomas costeras)
GFW_API_KEY=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esta_clave
