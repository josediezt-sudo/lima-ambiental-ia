# Postgres
POSTGRES_USER=lima_ambiental
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=lima_ambiental
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lima_ambiental:cambia_esta_clave@localhost:5432/lima_ambiental

# OpenAQ (https://explore.openaq.org/register)
# La ubicación/radio de búsqueda de estaciones se configura en config/municipio.yml,
# no aquí — ver config/municipio.example.yml.
OPENAQ_API_KEY=

# Ruta alternativa al archivo de configuración de la municipalidad (opcional,
# por defecto usa config/municipio.yml)
MUNICIPIO_CONFIG=

# Residuos — PNDA / CKAN (verificar el slug real del dataset en datosabiertos.gob.pe)
RESIDUOS_CKAN_BASE_URL=https://www.datosabiertos.gob.pe
RESIDUOS_CKAN_PACKAGE_ID=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esta_clave
